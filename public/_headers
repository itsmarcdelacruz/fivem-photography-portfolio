# Security headers for the static site on Cloudflare Pages (or compatible hosts).
# NOTE: the site is currently hosted on Vercel, which IGNORES this file — the
# authoritative config there is vercel.json at the repo root. This file is kept
# for portability in case the site moves to Cloudflare Pages.
# The Worker API sets its own headers separately.
# NOTE: update `connect-src` to your actual Worker origin and `img-src` to your
# R2 public URL before deploying, or the gallery/form requests will be blocked.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; img-src 'self' data: https://pub-b34ef142d0e84f21b71c2b007edfc45c.r2.dev; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.workers.dev; font-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'
