{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "types": []
  },
  "//": "Type-checking is scoped to the worker (pure logic). The vanilla-DOM frontend is covered by ESLint + the Vitest suite.",
  "include": ["worker/src/**/*.js"],
  "exclude": ["node_modules", "dist", "**/*.test.js"]
}
